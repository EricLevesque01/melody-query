# ─── API Keys ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
BESTBUY_API_KEY=...
EBAY_CLIENT_ID=...
EBAY_CLIENT_SECRET=...

# ─── Email / SMTP ──────────────────────────────────────────
